<svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- خلفية رمادية فاتحة -->
  <rect width="400" height="300" fill="#F9FAFB"/>
  
  <!-- جسم السيارة الرئيسي -->
  <path d="M80 180H320C330 180 340 170 340 160V140C340 130 330 120 320 120H280L260 100H140L120 120H80C70 120 60 130 60 140V160C60 170 70 180 80 180Z" fill="#E5E7EB"/>
  
  <!-- نوافذ السيارة -->
  <path d="M140 100H260L280 120H120L140 100Z" fill="#D1D5DB"/>
  <rect x="130" y="130" width="140" height="30" rx="5" fill="#D1D5DB"/>
  
  <!-- العجلات -->
  <circle cx="120" cy="180" r="20" fill="#6B7280"/>
  <circle cx="120" cy="180" r="12" fill="#374151"/>
  <circle cx="280" cy="180" r="20" fill="#6B7280"/>
  <circle cx="280" cy="180" r="12" fill="#374151"/>
  
  <!-- المصابيح الأمامية -->
  <ellipse cx="340" cy="150" rx="8" ry="12" fill="#FEF3C7"/>
  
  <!-- المصابيح الخلفية -->
  <ellipse cx="60" cy="150" rx="8" ry="12" fill="#FEE2E2"/>
  
  <!-- أيقونة سيارة في الوسط -->
  <g transform="translate(180, 220)">
    <circle cx="20" cy="20" r="25" fill="#3B82F6" opacity="0.1"/>
    <path d="M10 15 L30 15 L30 25 L10 25 Z" fill="#3B82F6" opacity="0.6"/>
    <path d="M15 10 L25 10 L25 15 L15 15 Z" fill="#3B82F6"/>
    <circle cx="15" cy="20" r="2" fill="#1E40AF"/>
    <circle cx="25" cy="20" r="2" fill="#1E40AF"/>
  </g>
  
  <!-- نص توضيحي -->
  <text x="200" y="270" text-anchor="middle" fill="#6B7280" font-family="Arial, sans-serif" font-size="14">صورة افتراضية للسيارة</text>
</svg>
